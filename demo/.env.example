# Demo backend configuration.

# High-entropy secret used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
COOKIE_SECRET=replace-me-with-a-32-byte-random-string

# Path to the official Codex CLI binary (must be installed and able to run
# `codex login --device-auth`). Defaults to `codex` on PATH.
CODEX_BIN=codex

# Port the demo Express server listens on (the Vite app proxies /api/codex here).
DEMO_SERVER_PORT=8787
